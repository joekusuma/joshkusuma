---
const { current = '' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const items = [
  { id: 'about',    href: `${base}/about`,    label: 'About me',          n: 'A' },
  { id: 'projects', href: `${base}/projects`, label: 'Projects & files',  n: 'P' },
  { id: 'photos',   href: `${base}/photographs`, label: 'Photographs',    n: 'F' },
  { id: 'research', href: `${base}/research`, label: 'Research',           n: 'R' },
  { id: 'skills',   href: `${base}/skills`,   label: 'Skills',            n: 'S' },
  { id: 'contact',  href: `${base}/contact`,  label: 'Contact',           n: 'C' },
];
---
<nav class="rail" aria-label="Primary">
  <a class="rail-home" href={`${base}/`} aria-label="Home — Josh Bennett Kusuma">
    <span class="mark">◺</span><span class="mark-t mono">AXIOM</span>
  </a>
  <span class="rail-line" aria-hidden="true"></span>
  <ul class="rail-list">
    {items.map((it) => (
      <li>
        <a href={it.href} class={`rail-item${current === it.id ? ' is-active' : ''}`} aria-current={current === it.id ? 'page' : undefined}>
          <span class="ico" aria-hidden="true">
            {it.id === 'about' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-7 8-7s8 2.6 8 7"/></svg>
            )}
            {it.id === 'projects' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M6 12h9"/></svg>
            )}
            {it.id === 'photos' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="6" width="18" height="14" rx="1.6"/><circle cx="12" cy="13" r="3.4"/><path d="M8 6l1.5-2h5L16 6"/></svg>
            )}
            {it.id === 'research' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M5 4h9l4 4v12a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1z"/><path d="M13 4v5h5M8 13h7M8 16.5h7"/></svg>
            )}
            {it.id === 'skills' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="3.2"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M19.1 4.9L17 7M7 17l-2.1 2.1"/></svg>
            )}
            {it.id === 'contact' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="5" width="18" height="14" rx="1.5"/><path d="m3.5 6.5 8.5 6 8.5-6"/></svg>
            )}
          </span>
          <span class="rail-label"><span class="dash" aria-hidden="true"></span>{it.label}</span>
          <span class="rail-tag mono" aria-hidden="true">{it.n}</span>
        </a>
      </li>
    ))}
  </ul>
  <span class="rail-coord tick" aria-hidden="true">y·nav</span>
</nav>

<style>
  .rail {
    position: fixed; left: 0; top: 0; height: 100vh; width: 76px;
    display: flex; flex-direction: column; align-items: center;
    padding: 20px 0; z-index: 40;
    background: color-mix(in srgb, var(--paper) 78%, transparent);
    backdrop-filter: blur(6px);
    border-right: 1px solid var(--line-2);
  }
  .rail-home { display: flex; flex-direction: column; align-items: center; gap: 4px; text-decoration: none; }
  .mark { font-size: 1.4rem; line-height: 1; color: var(--ink); transform: translateY(1px); }
  .mark-t { font-size: .52rem; letter-spacing: .18em; color: var(--graphite); }
  .rail-line { flex: 0 0 auto; width: 1px; height: 34px; background: var(--line-2); margin: 16px 0; }

  .rail-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 20px; flex: 1 1 auto; justify-content: center; }
  .rail-item { position: relative; display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; color: var(--ink); transition: transform .26s var(--ease); }
  .ico { display: grid; place-items: center; width: 40px; height: 40px; border: 1.5px solid var(--line-3); border-radius: 50%; background: var(--paper); transition: border-color .24s var(--ease), background .24s var(--ease), color .24s var(--ease); }
  .ico svg { width: 20px; height: 20px; }

  /* hover-enlarge + reveal label (per wireframe) */
  .rail-item:hover { transform: scale(1.34); }
  .rail-item:hover .ico { border-color: var(--blue); color: var(--blue); }
  .rail-item.is-active .ico { background: var(--ink); border-color: var(--ink); color: var(--paper); }

  .rail-label {
    position: absolute; left: 52px; top: 50%; transform: translateY(-50%) translateX(-6px);
    display: flex; align-items: center; gap: 10px; white-space: nowrap;
    font-family: var(--font-mono); font-size: .74rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase;
    color: var(--blue);
    opacity: 0; pointer-events: none; transition: opacity .2s var(--ease), transform .24s var(--ease);
    background: var(--paper); padding: 3px 9px 3px 0;
  }
  .rail-label .dash { width: 18px; height: 1.5px; background: var(--blue); }
  .rail-item:hover .rail-label,
  .rail-item:focus-visible .rail-label { opacity: 1; transform: translateY(-50%) translateX(0) scale(.78); transform-origin: left center; }

  .rail-tag { position: absolute; right: -2px; top: -3px; font-size: .5rem; color: var(--faint); }
  .rail-coord { writing-mode: vertical-rl; margin-top: 8px; font-size: .5rem; }

  /* ---------- mobile: bottom tab bar ---------- */
  @media (max-width: 860px) {
    .rail {
      left: 0; top: auto; bottom: 0; height: 60px; width: 100%;
      flex-direction: row; padding: 0 4px;
      border-right: 0; border-top: 1px solid var(--line-2);
      justify-content: space-between; align-items: center;
    }
    .rail-home { flex-direction: row; gap: 6px; padding-left: 14px; }
    .mark { font-size: 1.15rem; }
    .mark-t { font-size: .6rem; }
    .rail-line, .rail-coord { display: none; }
    .rail-list { flex-direction: row; gap: 4px; flex: 0 0 auto; padding-right: 6px; }
    .rail-item { width: 46px; height: 46px; }
    .ico { width: 38px; height: 38px; }
    .rail-item:hover { transform: none; }
    .rail-label { display: none; }
    .rail-tag { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .rail-item, .rail-label { transition: none; }
    .rail-item:hover { transform: none; }
  }
</style>
