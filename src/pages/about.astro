---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { pic } from '../data/projects.js';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const dossier = [
  {
    n: 'A', head: 'Profile',
    body: 'Josh Bennett Kusuma — a JC1 student at SIS Semarang and the designer behind AXIOM. He works across fashion, brand identity, editorial layout, industrial concepts and 3D printing, tying them together with one instinct: take what moves the wider world and make it land at home.',
  },
  {
    n: 'B', head: 'Education',
    body: 'Currently in Junior College (JC1) at SIS Semarang, Indonesia. Design work spans self-directed briefs (streetwear, brand systems, editorial) and coursework in visual art and design.',
  },
  {
    n: 'C', head: 'Achievements',
    list: [
      'Reached the PRC finals in a Chinese-language competition.',
      'Top 2 student in Secondary 1 — awarded a scholarship.',
      'Outstanding Award for a Chinese story.',
      'Top 3, poster competition for Indonesia’s 76th Independence Day.',
    ],
  },
  {
    n: 'D', head: 'Extracurricular',
    body: 'Member of the Leo Club, contributing to charity drives and community service — and designing the club’s banners and promotional material, where the design practice meets a real audience.',
  },
];
---
<Base current="about" title="About">
  <section class="wrap about-top">
    <div class="eyebrow"><span class="n">00</span> About the designer</div>
    <div class="about-grid">
      <figure class="portrait">
        <Image src={pic('about-portrait')} alt="Josh Bennett Kusuma" widths={[380, 700]} sizes="(max-width:820px) 90vw, 40vw" />
        <span class="portrait-tag mono">J.B. KUSUMA</span>
        <span class="regmark" style="top:8px;right:8px"></span>
      </figure>

      <div class="about-intro">
        <div class="hello mono" aria-label="Hello in three languages">
          <span>Hello</span><span class="sep">/</span><span>Halo</span><span class="sep">/</span><span>你好</span>
        </div>
        <h1>I design so the world’s aesthetics can live locally.</h1>
        <p>
          I’m Josh — a student designer who treats every project as a full build, not a mood board.
          A hoodie ships with a seam-by-seam tech pack and its own bag. A café mascot grows into a
          whole brand. A trip to Tokyo becomes a typographic system. A curiosity about mechanisms
          becomes a forty-part printed tentacle.
        </p>
        <p>
          The thread is <em>access</em>: pulling global taste — streetwear, editorial, product design —
          into something people around me can actually hold, wear, or use.
        </p>
        <div class="handles">
          <a class="handle" href="https://instagram.com/jbkusuma" target="_blank" rel="noopener"><span class="mono">IG</span> @jbkusuma</a>
          <a class="handle" href="https://instagram.com/theaxiom.one" target="_blank" rel="noopener"><span class="mono">IG</span> @theaxiom.one</a>
        </div>
      </div>
    </div>
  </section>

  <section class="wrap about-dossier">
    <div class="dossier">
      {dossier.map((d) => (
        <div class="dcard">
          <div class="dcard-head"><span class="dcard-n mono">{d.n}</span><h2>{d.head}</h2></div>
          {d.body && <p>{d.body}</p>}
          {d.list && (
            <ul class="dcard-list">
              {d.list.map((it) => <li>{it}</li>)}
            </ul>
          )}
        </div>
      ))}
    </div>
  </section>

  <section class="wrap about-cta-wrap">
    <div class="about-cta">
      <div>
        <span class="label-blue">Next</span>
        <p class="cta-line">See the work, or get in touch.</p>
      </div>
      <div class="cta-btns">
        <a class="btn" href={`${base}/projects`}>View projects <span class="arw">→</span></a>
        <a class="btn ghost" href={`${base}/contact`}>Contact</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .about-top { padding-top: 2rem; }
  .about-grid { display: grid; grid-template-columns: .82fr 1.18fr; gap: clamp(1.6rem, 4vw, 3.4rem); align-items: center; }
  .portrait { position: relative; margin: 0; border: 1.5px solid var(--ink); overflow: hidden; background: var(--paper-2); aspect-ratio: 4 / 5; }
  .portrait img { width: 100%; height: 100%; object-fit: cover; }
  .portrait-tag { position: absolute; bottom: 0; left: 0; font-size: .58rem; color: var(--paper); background: var(--ink); padding: 3px 8px; letter-spacing: .1em; }

  .hello { display: flex; gap: .7rem; align-items: center; font-size: .82rem; color: var(--graphite); letter-spacing: .1em; margin-bottom: 1.2rem; }
  .hello .sep { color: var(--line-3); }
  .about-intro h1 { font-size: clamp(1.9rem, 4.2vw, 3.1rem); font-weight: 800; letter-spacing: -.03em; line-height: 1.02; margin-bottom: 1.2rem; }
  .about-intro p { font-size: clamp(1rem, 1.6vw, 1.14rem); line-height: 1.68; color: var(--ink-soft); margin: 0 0 1rem; }
  .about-intro em { font-style: italic; color: var(--blue); font-weight: 500; }
  .handles { display: flex; flex-wrap: wrap; gap: .8rem; margin-top: 1.6rem; }
  .handle { display: inline-flex; align-items: center; gap: .5rem; font-size: .84rem; font-weight: 600; padding: .5rem .8rem; border: 1.5px solid var(--line-2); transition: border-color .2s, color .2s; }
  .handle .mono { font-size: .6rem; color: var(--paper); background: var(--ink); padding: 2px 5px; }
  .handle:hover { border-color: var(--blue); color: var(--blue); }

  .about-dossier { margin-top: clamp(2.6rem, 6vw, 4.5rem); }
  .dossier { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
  .dcard { border: 1.5px solid var(--line-2); padding: 1.4rem 1.5rem; background: var(--paper); }
  .dcard-head { display: flex; align-items: baseline; gap: .8rem; margin-bottom: .9rem; padding-bottom: .8rem; border-bottom: 1px solid var(--line); }
  .dcard-n { color: var(--blue); font-size: .8rem; font-weight: 700; }
  .dcard-head h2 { font-size: 1.3rem; font-weight: 800; letter-spacing: -.01em; }
  .dcard p { font-size: .92rem; line-height: 1.62; color: var(--ink-soft); margin: 0; }
  .dcard-list { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: .6rem; }
  .dcard-list li { font-size: .9rem; line-height: 1.5; color: var(--ink-soft); padding-left: 1.3rem; position: relative; }
  .dcard-list li::before { content: "→"; position: absolute; left: 0; color: var(--blue); font-family: var(--font-mono); font-size: .8rem; }

  .about-cta-wrap { margin-top: 3rem; }
  .about-cta { display: flex; justify-content: space-between; align-items: center; gap: 2rem; flex-wrap: wrap; border-top: 1.5px solid var(--ink); padding-top: 2rem; }
  .cta-line { font-size: clamp(1.3rem, 3vw, 2rem); font-weight: 800; letter-spacing: -.02em; margin: .5rem 0 0; }
  .cta-btns { display: flex; gap: .8rem; flex-wrap: wrap; }

  @media (max-width: 820px) {
    .about-grid { grid-template-columns: 1fr; }
    .portrait { max-width: 340px; }
    .dossier { grid-template-columns: 1fr; }
  }
</style>
