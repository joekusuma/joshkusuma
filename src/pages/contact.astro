---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import axiomLogo from '../assets/axiom-logo.webp';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const channels = [
  { tag: 'DESIGN', label: '@theaxiom.one', sub: 'Portfolio & project work', href: 'https://instagram.com/theaxiom.one' },
  { tag: 'PERSONAL', label: '@jbkusuma', sub: 'Everything else', href: 'https://instagram.com/jbkusuma' },
];
---
<Base current="contact" title="Contact">
  <section class="wrap ct">
    <div class="eyebrow"><span class="n">05</span> Contact</div>

    <div class="ct-hero">
      <div class="ct-hero-l">
        <h1>Let’s build<br/>something.</h1>
        <p class="ct-lede">
          Open to briefs, collaborations, and commissions — fashion, brand, editorial, or 3D.
          The fastest way to reach me is a DM.
        </p>
      </div>

      <aside class="ct-card">
        <div class="ct-card-top">
          <Image class="ct-logo" src={axiomLogo} alt="AXIOM" widths={[150, 300]} sizes="132px" />
          <span class="ct-mark-t mono">STUDIO</span>
          <span class="regmark" style="top:10px;right:10px"></span>
        </div>
        <dl class="ct-card-list">
          <div><dt class="mono">STUDIO</dt><dd>Josh Bennett Kusuma</dd></div>
          <div><dt class="mono">BASED IN</dt><dd>Semarang, Indonesia</dd></div>
          <div><dt class="mono">FIELDS</dt><dd>Fashion · Brand · Editorial · 3D</dd></div>
          <div><dt class="mono">STATUS</dt><dd><span class="dot" aria-hidden="true"></span>Open for work</dd></div>
        </dl>
        <div class="ct-card-foot mono">REF · CONTACT / 05</div>
      </aside>
    </div>

    <div class="ct-channels">
      {channels.map((c) => (
        <a class="ch" href={c.href} target="_blank" rel="noopener">
          <div class="ch-l">
            <span class="ch-tag mono">{c.tag}</span>
            <strong class="ch-label">{c.label}</strong>
            <span class="ch-sub">{c.sub}</span>
          </div>
          <span class="ch-arw" aria-hidden="true">↗</span>
        </a>
      ))}
    </div>

    <a class="btn ghost ct-back" href={`${base}/projects`}>← Back to projects</a>
  </section>
</Base>

<style>
  .ct { padding-top: 2rem; min-height: 70vh; }

  .ct-hero { display: grid; grid-template-columns: 1.25fr .75fr; gap: clamp(1.6rem, 4vw, 3.4rem); align-items: stretch; margin-bottom: clamp(2rem, 5vw, 3.4rem); }
  .ct-hero-l { display: flex; flex-direction: column; justify-content: center; }
  .ct-hero h1 { font-size: clamp(2.8rem, 7.5vw, 5.6rem); font-weight: 900; letter-spacing: -.04em; line-height: .9; }
  .ct-lede { font-size: clamp(1.05rem, 1.8vw, 1.22rem); color: var(--graphite); line-height: 1.6; max-width: 42ch; margin-top: 1.3rem; }

  .ct-card { border: 1.5px solid var(--ink); display: flex; flex-direction: column; background: var(--paper); }
  .ct-card-top { position: relative; display: flex; align-items: center; gap: .7rem; padding: 1.3rem 1.3rem 1.2rem; border-bottom: 1.5px solid var(--ink); background: var(--paper-2); }
  .ct-mark { font-size: 2.2rem; line-height: 1; }
  .ct-logo { width: 132px; height: auto; display: block; }
  .ct-mark-t { font-size: .64rem; letter-spacing: .18em; line-height: 1.3; color: var(--graphite); }
  .ct-card-list { margin: 0; padding: .4rem 0; flex: 1; }
  .ct-card-list > div { display: flex; flex-direction: column; gap: .25rem; padding: .8rem 1.3rem; border-bottom: 1px solid var(--line); }
  .ct-card-list > div:last-child { border-bottom: 0; }
  .ct-card-list dt { font-size: .6rem; letter-spacing: .12em; color: var(--faint); }
  .ct-card-list dd { margin: 0; font-size: .95rem; font-weight: 600; display: inline-flex; align-items: center; gap: .5rem; }
  .ct-card-foot { font-size: .58rem; color: var(--faint); padding: .7rem 1.3rem; border-top: 1.5px solid var(--ink); text-align: right; }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: #16a34a; display: inline-block; box-shadow: 0 0 0 3px color-mix(in srgb, #16a34a 22%, transparent); }

  .ct-channels { border-top: 1.5px solid var(--ink); }
  .ch { display: flex; justify-content: space-between; align-items: center; gap: 1rem; padding: 1.5rem .4rem; border-bottom: 1px solid var(--line-2); transition: background .2s var(--ease), padding-left .22s var(--ease); }
  .ch:hover { background: var(--paper-2); padding-left: 1.2rem; }
  .ch-l { display: grid; gap: .3rem; }
  .ch-tag { font-size: .62rem; color: var(--blue); letter-spacing: .14em; }
  .ch-label { font-size: clamp(1.6rem, 4vw, 2.6rem); font-weight: 800; letter-spacing: -.02em; line-height: 1; }
  .ch-sub { font-size: .84rem; color: var(--graphite); }
  .ch-arw { font-size: 1.6rem; color: var(--ink); transition: transform .2s var(--ease), color .2s; }
  .ch:hover .ch-arw { transform: translate(4px, -4px); color: var(--blue); }

  .ct-back { margin-top: 1.6rem; }

  @media (max-width: 780px) {
    .ct-hero { grid-template-columns: 1fr; }
    .ct-card { max-width: 380px; }
  }
</style>
